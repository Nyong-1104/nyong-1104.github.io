# Copy to /etc/pokepop-gemrate.env and chmod 600
INSTALL_DIR=/opt/pokepop
GEMRATE_SLEEP_SEC=60
GIT_PUSH=1
GIT_AUTHOR_NAME=pokepop-vps
GIT_AUTHOR_EMAIL=41898282+github-actions[bot]@users.noreply.github.com
LOG_DIR=/var/log/pokepop

# Optional: deploy key for git push (uncomment both lines)
# export GIT_SSH_COMMAND='ssh -i /home/pokepop/.ssh/pokepop_deploy -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new'
