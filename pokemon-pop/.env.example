# eBay Browse API (Production App ID / Cert ID from developer.ebay.com)
# Also add the same values as GitHub Actions secrets:
#   Settings → Secrets and variables → Actions → EBAY_CLIENT_ID / EBAY_CLIENT_SECRET
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Optional: card×lang searches per fetch_live run
EBAY_FETCH_LIMIT=200
